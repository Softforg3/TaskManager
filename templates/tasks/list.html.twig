{% extends 'base.html.twig' %}

{% block title %}Tasks - TaskManager{% endblock %}

{% block navbar %}
<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="#">TaskManager</a>
        <div class="d-flex align-items-center">
            <a href="{{ path('web_users') }}" class="nav-link me-3">Users</a>
            <a href="{{ path('web_tasks') }}" class="nav-link me-3 fw-bold">Tasks</a>
            <span class="navbar-text me-3">
                {{ app.user.name }}
                <span class="badge {{ app.user.role.value == 'ROLE_ADMIN' ? 'badge-admin' : 'badge-member' }}">
                    {{ app.user.role.value == 'ROLE_ADMIN' ? 'Admin' : 'Member' }}
                </span>
            </span>
            <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </div>
    </div>
</nav>
{% endblock %}

{% block body %}
{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
{% endfor %}
<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Tasks ({{ tasks|length }})</h5>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Assigned To</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                {% for task in tasks %}
                <tr>
                    <td>{{ task.title }}</td>
                    <td><small class="text-muted">{{ task.description|length > 50 ? task.description|slice(0, 50) ~ '...' : task.description }}</small></td>
                    <td>
                        {% if task.status.value == 'TODO' %}
                            <span class="badge bg-secondary">To Do</span>
                        {% elseif task.status.value == 'IN_PROGRESS' %}
                            <span class="badge" style="background-color: #2563eb;">In Progress</span>
                        {% else %}
                            <span class="badge bg-success">Done</span>
                        {% endif %}
                    </td>
                    <td>
                        {% set assignedUser = users[task.assignedUserId.toString] ?? null %}
                        {{ assignedUser ? assignedUser.name : task.assignedUserId.toString }}
                    </td>
                    <td><small class="text-muted">{{ task.createdAt|date('Y-m-d H:i') }}</small></td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">No tasks yet.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
